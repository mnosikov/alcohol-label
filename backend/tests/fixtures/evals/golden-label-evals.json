{
  "name": "golden-label-verification-evals",
  "version": 1,
  "cases": [
    {
      "id": "vision_pass_after_low_ocr",
      "description": "Low OCR confidence escalates to vision; vision extracts all required evidence.",
      "application": {
        "brand_name": "OLD TOM DISTILLERY",
        "class_type": "Bourbon",
        "alcohol_content": "45% Alc./Vol.",
        "net_contents": "750 mL"
      },
      "ocr": {
        "text": "",
        "confidence": 0.0
      },
      "vision": {
        "extracted": {
          "brand_name": "OLD TOM DISTILLERY",
          "class_type": "Bourbon",
          "alcohol_content": "45% Alc./Vol.",
          "net_contents": "750 mL",
          "government_warning": "__CANONICAL_GOVERNMENT_WARNING__",
          "warning_prefix_bold": true
        }
      },
      "expected_recommendation": "PASS",
      "expected_status": "machine_passed",
      "tags": ["pass", "ocr_escalation", "vision"]
    },
    {
