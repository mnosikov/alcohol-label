APP_NAME=alcohol-label-verifier
DATABASE_URL=postgresql+psycopg://label:label@postgres:5432/label
POSTGRES_DB=label
POSTGRES_USER=label
POSTGRES_PASSWORD=label
UPLOAD_DIR=/data/uploads
STATIC_DIR=/app/frontend/dist
MAX_UPLOAD_MB=15
VISION_PROVIDER=noop
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=10.0
REVIEW_TOKEN=
PUBLIC_REVIEW_ENABLED=false
OCR_ENABLED=true
SEED_DEMO_DATA=false
RUN_DB_STARTUP=true
SAMPLED_REVIEW_RATE=0.0
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=alcohol-label-verifier
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
DOMAIN=label.af5.org
TRAEFIK_NETWORK=dokploy-network
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
